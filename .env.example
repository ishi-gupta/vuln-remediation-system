# ──────────────────────────────────────────────────────────────
# Environment Variables for the Vulnerability Remediation System
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# GitHub Personal Access Token (required)
# Needs 'repo' scope for creating issues and labeling
# Create at: https://github.com/settings/tokens/new?scopes=repo
GITHUB_TOKEN=

# Target repository to scan and remediate (owner/repo)
GITHUB_REPO=ishi-gupta/superset

# Devin API Key (required for orchestrator)
# Must be a Service User key (not a Personal Access Token)
# Create at: https://app.devin.ai/settings → Service Users
DEVIN_API_KEY=

# Devin Organization ID (required for v3 API)
# Found at: https://app.devin.ai/settings
DEVIN_ORG_ID=

# Dashboard settings (optional)
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# Scanner settings (optional)
SCAN_SEVERITY_THRESHOLD=LOW
MAX_ISSUES_PER_RUN=50
